{
  "name": "ai-pixel-image-cuter",
  "version": "0.1.0",
  "private": true,
  "description": "Mac sprite sheet cutter and rearranger for pixel art.",
  "main": "dist-electron/main/index.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:app": "wait-on tcp:5173 dist-electron/main/index.js && electronmon .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder --mac dir zip",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.openai.pixelcutter",
    "productName": "Pixel Sprite Cuter",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design"
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "electronmon": "^2.0.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "wait-on": "^8.0.3"
  }
}
